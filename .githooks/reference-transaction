#!/usr/bin/env bash
[ "$1" = "prepared" ] || exit 0
ZERO="0000000000000000000000000000000000000000"
while read -r old new ref; do
  case "$ref" in
    refs/heads/main) ;;
    refs/heads/*)
      if [ "$old" = "$ZERO" ]; then
        echo "BLOCKED by .githooks/reference-transaction: refusing to create branch '${ref#refs/heads/}'." >&2
        echo "Policy: all work happens on main." >&2
        exit 1
      fi
      ;;
  esac
done
exit 0
