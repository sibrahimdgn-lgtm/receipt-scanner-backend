# ── Alibaba Qwen Vision ───────────────────────────────────────
QWEN_API_KEY=your_qwen_api_key_here
# Optional compatibility aliases / overrides
# CREATIVE_QWEN_API_KEY=your_qwen_api_key_here
# DASHSCOPE_API_KEY=your_qwen_api_key_here
# CREATIVE_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# CREATIVE_QWEN_VL_MODEL=qwen3-vl-plus

# ── Firebase Admin (Backend) ─────────────────────────────────
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Option A (preferred on Render): paste the service account JSON as one line
FIREBASE_SERVICE_ACCOUNT={"projectId":"your-project-id","clientEmail":"firebase-adminsdk@example.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}

# Legacy compatibility: older env name still works
# FIREBASE_SERVICE_ACCOUNT_JSON={"projectId":"your-project-id","clientEmail":"firebase-adminsdk@example.iam.gserviceaccount.com","privateKey":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}

# Option B: provide individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option C: keep the default local key file in the project root
# ./firebase-service-account.json

# ── Server ───────────────────────────────────────────────────
PORT=3000
